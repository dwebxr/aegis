# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.js
.yarn/install-state.gz
packages/*/node_modules
packages/*/dist
packages/*/package-lock.json

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# local env files
.env
.env*.local
.env.ic

# dfx local replica
.dfx/

# canister pre-upgrade snapshots (produced by scripts/canister-backup.sh)
canister-backups/

# k6 load test result snapshots
loadtest/last-run.json

# mops (Motoko package manager)
.mops/

# vercel
.vercel

# serwist generated service worker
public/sw.js
public/sw.js.map

# playwright
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/

# typescript
*.tsbuildinfo
next-env.d.ts

# claude code harness ephemeral state
.claude/worktrees/
.claude/evaluations/
