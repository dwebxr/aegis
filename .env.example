# Required: Anthropic API key for content analysis
ANTHROPIC_API_KEY=

# Required: IC canister ID (deployed aegis_backend canister)
NEXT_PUBLIC_CANISTER_ID=

# Optional: IC host (defaults to https://icp-api.io for mainnet)
NEXT_PUBLIC_IC_HOST=https://icp-api.io

# Optional: Internet Identity URL (defaults to https://id.ai — II's primary origin).
# Must be id.ai: a non-primary origin makes II redirect and breaks AuthClient login.
NEXT_PUBLIC_INTERNET_IDENTITY_URL=https://id.ai

# Push Notifications (VAPID)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@dwebxr.xyz

# Push-token canister authz: Ed25519 secret (base64, 32 bytes) whose principal
# is registered as a controller of aegis_backend. /api/push/token uses this to
# verify caller-supplied subscription endpoints against canister state before
# minting tokens. Generate + register via scripts/add-push-server-controller.sh
PUSH_SERVER_PRIVATE_KEY=

# Vercel KV (rate limiting, daily budget tracking)
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional: daily Anthropic API call cap (integer count, default 500).
# Parsed via parseInt() — fractional values are truncated. NOT a USD amount.
ANTHROPIC_DAILY_BUDGET=500

# Optional: canonical app URL (defaults to https://aegis-ai.xyz)
NEXT_PUBLIC_APP_URL=https://aegis-ai.xyz

# D2A CORS (comma-separated origins; defaults to ICP canister + app URL)
D2A_CORS_ORIGINS=

# x402 D2A Payment Gateway
X402_RECEIVER_ADDRESS=
X402_NETWORK=eip155:84532
X402_FACILITATOR_URL=https://x402.org/facilitator
X402_PRICE=$0.01
# Optional: gate x402 free-tier preview ("true" enables bypass, default off)
X402_FREE_TIER_ENABLED=

# Sentry Error Tracking — production monitoring is DISABLED without DSN
# Without NEXT_PUBLIC_SENTRY_DSN, no errors are captured in production.
# Set via: vercel env add NEXT_PUBLIC_SENTRY_DSN production
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Optional: build SHA surfaced in /api/health (Vercel sets VERCEL_GIT_COMMIT_SHA
# automatically; this override is for self-hosted deploys).
NEXT_PUBLIC_BUILD_SHA=

# OpenPay JPYC gate (x402 v1, Polygon eip155:137) for /api/d2a/briefing-jpyc.
# The route serves 503 until OPENPAY_MERCHANT_ADDRESS is set AND the resource
# URL is registered in the OpenPay catalog. Accepts (price/fees) come from the
# catalog at runtime — no price env needed.
OPENPAY_MERCHANT_ADDRESS=
# Optional overrides (defaults: https://open-pay.jp / the aegis-ai.xyz route URL / canonical JPYC)
OPENPAY_URL=
OPENPAY_RESOURCE_URL=
OPENPAY_JPYC_ASSET=
