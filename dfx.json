{
  "version": 1,
  "canisters": {
    "aegis_backend": {
      "type": "motoko",
      "main": "canisters/aegis_backend/main.mo"
    },
    "mock_ledger": {
      "type": "motoko",
      "main": "canisters/mock_ledger/main.mo",
      "comment": "TEST-ONLY mock ICRC ledger for local staking tests. Do NOT deploy to --network ic."
    },
    "internet_identity": {
      "type": "pull",
      "id": "rdmx6-jaaaa-aaaaa-aaadq-cai"
    }
  },
  "defaults": {
    "build": {
      "packtool": "mops sources"
    }
  },
  "output_env_file": ".env.ic",
  "networks": {
    "local": {
      "bind": "127.0.0.1:4943",
      "type": "ephemeral",
      "replica": {
        "subnet_type": "application"
      }
    },
    "ic": {
      "providers": ["https://icp-api.io"],
      "type": "persistent"
    }
  }
}
